# Sao chép thành `.env` và điền khóa (không commit `.env`).
# Backend API base (AI proxy + wallet operations)
EXPO_PUBLIC_BACKEND_API_BASE=

# Payments microservice (top-up intent + verify). Unset → top-up intents disabled; see docs/PILOT_TRUST_ENV.md
EXPO_PUBLIC_PAYMENTS_API_BASE=

# Firebase client (bắt buộc cho walletOps: anonymous auth + ID token). Bật "Anonymous" trong Firebase Console → Authentication.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# Khuyến nghị (đủ cho initializeApp):
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# Tuỳ chọn:
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=

# G3 App Check (Expo web only in this repo — reCAPTCHA Enterprise site key from Firebase Console → App Check → Web)
# EXPO_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=
# Optional web debug (see Firebase debug provider docs):
# EXPO_PUBLIC_FIREBASE_APP_CHECK_DEBUG=1
# EXPO_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN=

# G5 release label only (native_pilot | web_commercial | mixed_pilot) — see docs/G5_PLATFORM_TRUST.md
# EXPO_PUBLIC_RELEASE_TRUST_PROFILE=mixed_pilot

# Stripe (dev client / production). Apple Pay cần merchantIdentifier khớp Xcode / App Store Connect.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_STRIPE_MERCHANT_IDENTIFIER=
# Deep link scheme cho 3DS / redirect (khớp scheme app).
EXPO_PUBLIC_STRIPE_URL_SCHEME=ket-noi-eu

# Optional backend for shared TTS cache (backend-first audio reuse):
# - GET  {EXPO_PUBLIC_TTS_CACHE_API_BASE}/tts/cache?key=...
# - POST {EXPO_PUBLIC_TTS_CACHE_API_BASE}/tts/cache/generate
EXPO_PUBLIC_TTS_CACHE_API_BASE=
# Optional cache controls:
# - TTS_CACHE_VERSION: bump value to force refresh all cached audio
# - TTS_CACHE_TTL_DAYS: <= 0 means no expiration
EXPO_PUBLIC_TTS_CACHE_VERSION=v1
EXPO_PUBLIC_TTS_CACHE_TTL_DAYS=90

# B2B merchant queue (G1/G2): prefer HTTPS b2bStaffQueueSnapshot (Firebase ID token + custom claim b2bTenantId)
EXPO_PUBLIC_B2B_STAFF_QUEUE_PREFER_HTTPS=
# G2: When PREFER_HTTPS=1 and HTTPS fails, set to 1 to allow legacy Firestore reads (requires EXPO_PUBLIC_B2B_DEV_TENANT_ID). Unset/0 = no fallback.
EXPO_PUBLIC_B2B_FIRESTORE_QUEUE_FALLBACK=
# Dev-only: tenant id for legacy Firestore SDK reads (not production merchant RBAC)
EXPO_PUBLIC_B2B_DEV_TENANT_ID=

# AI prompt profile for QA A/B testing:
# - default: tone tự nhiên cân bằng
# - strict: bám sát mục tiêu CSKH/đặt lịch, ít lan man
EXPO_PUBLIC_AI_PROMPT_PROFILE=default

# Observability / Operations
# Environment label used in telemetry envelopes (development | staging | production)
EXPO_PUBLIC_APP_ENV=development
# Optional telemetry ingest endpoint for production operational signals
# EXPO_PUBLIC_OBS_INGEST_URL=
# Do NOT place secrets in EXPO_PUBLIC_* (bundled to client). Protect ingest endpoint via server-side controls.
# Optional remote ops config endpoint (GET JSON: { killSwitch, readOnlyMode, disabledFeatures[] })
# EXPO_PUBLIC_OPS_CONFIG_URL=
# Optional timeout for ops config fetch; cached config is used on failure
EXPO_PUBLIC_OPS_CONFIG_TIMEOUT_MS=2500
# Emergency static overrides (build-time): 1 = enabled
EXPO_PUBLIC_OPS_KILL_SWITCH=0
EXPO_PUBLIC_OPS_READ_ONLY_MODE=0
# Comma-separated features to disable fast without app rebuild
EXPO_PUBLIC_OPS_DISABLED_FEATURES=

# Admin debug surface (internal/dev only)
# EXPO_PUBLIC_ENABLE_ADMIN_DEBUG=1
# Dev-only unlock PIN (client-visible env; never rely on it in release)
# EXPO_PUBLIC_ADMIN_PIN=
# Release debug requires explicit insecure acknowledgment string:
# EXPO_PUBLIC_ENABLE_ADMIN_DEBUG_RELEASE_ACK=I_UNDERSTAND_INSECURE_CLIENT_DEBUG_SURFACE
