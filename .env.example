# =============================================================================
# ViGlobal API (Node) — mẫu biến môi trường. Sao chép thành `.env` và điền giá trị thật.
# Không commit file `.env` lên Git.
# =============================================================================

# --- Bắt buộc cho mọi route dùng Prisma (gồm OTP: EmailOtpChallenge + EmailOtpSendLog) ---
# PostgreSQL connection string (ví dụ Neon / Supabase / Docker local).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# --- Bắt buộc cho luồng OTP & JWT session (tối thiểu 16 ký tự) ---
# Nếu thiếu hoặc < 16 ký tự → API trả 500 "Authentication service unavailable" khi gọi /email/otp/request.
JWT_SECRET=thay-bang-chuoi-ngau-nhien-toi-thieu-16-ky-tu

# --- Bắt buộc để gửi email OTP qua Amazon SES (EmailService + EmailOtpService) ---
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Địa chỉ From phải đã verify trong SES (Sandbox: cả From và To đều phải verify).
# Hỗ trợ một trong các tên: SES_FROM_EMAIL | MAIL_FROM | AWS_SES_SENDER_EMAIL
AWS_SES_SENDER_EMAIL=you@verified-domain.example
# SES_REGION=eu-north-1

# --- AI Receptionist pilot lead relay (API server; optional) ---
# Inbox nhận lead pilot từ POST /api/ai-receptionist/pilot-leads/email (xem docs/ops/VIONA_COMMERCIAL_PILOT_OPS_RUNBOOK.md).
# VIONA_AI_RECEPTIONIST_LEAD_RECIPIENT_EMAIL=ops-pilot-inbox@example.com

# --- Tuỳ chọn API server ---
# API_PORT=8787

# --- API hardening (Express + Socket.IO) ---
# API_CORS_ORIGINS=https://your-app.example.com,http://localhost:8081
# TRUST_PROXY_HOPS=0
