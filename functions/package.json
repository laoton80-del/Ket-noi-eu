    "receipt:seed": "node scripts/seed-payment-receipt.cjs"
  },
  "dependencies": {
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "typescript": "~5.7.2"
  }
}
