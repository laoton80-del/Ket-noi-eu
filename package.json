{
  "name": "ket-noi-eu",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/release-smoke.mjs",
    "preflight": "npm run typecheck && npm run smoke",
    "preflight:with-functions": "npm run preflight && npm run functions:verify-bundle",
    "trust:preflight": "node scripts/trust-preflight.mjs",
    "trust:native-readiness": "node scripts/trust-native-readiness.mjs",
    "trust:live": "node scripts/trust-live-smoke.mjs",
    "preflight:release": "npm run preflight:with-functions && npm run trust:preflight",
    "preflight:commercial": "npm run preflight:release && node scripts/commercial-release-gate.mjs",
    "preflight:commercial:strict": "npm run preflight:release && node scripts/commercial-release-gate.mjs --strict",
    "commercial:preflight": "node scripts/commercial-readiness-preflight.mjs",
    "ci:expo-readiness": "npx expo config --type public && npx expo-doctor",
    "ci:release-discipline": "node scripts/ci-release-discipline.mjs",
    "security:preflight": "node scripts/security-preflight.mjs",
    "ops:preflight": "node scripts/ops-preflight.mjs",
    "functions:build": "npm run build --prefix functions",
    "functions:verify-bundle": "node scripts/verify-functions-bundle.mjs",
    "b2b:verify-phase32": "npm run b2b:verify-phase32 --prefix functions",
    "b2b:g1-set-claims": "node functions/scripts/b2b-set-staff-claims.cjs",
    "verify:receipt": "node scripts/verify-receipt-strictness.mjs",
    "check:commercial-mapping": "tsx scripts/check-commercial-flagship-mapping.ts",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo-google-fonts/be-vietnam-pro": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/app-check": "^23.8.8",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@stripe/stripe-react-native": "0.50.3",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "firebase": "^11.10.0",
    "lucide-react-native": "^1.7.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av",
          "expo-modules-core",
          "expo-image-loader"
        ]
      }
    }
  },
  "private": true
}
