# Copy to `.env` for local Prisma / Node scripts (never commit real secrets).
# Used by: `npx prisma migrate dev`, `npx prisma db push`, `prisma validate`, and `getPrisma()`.

DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/viglobal?schema=public"

# REST API (`npm run api:dev`) — never commit real secrets.
API_PORT=8787
JWT_SECRET="change-me-min-16-chars-for-hs256"
JWT_EXPIRES_IN="7d"

# User.pinCode must be a bcrypt hash (e.g. from bcrypt.hash(pin, 12)) — never store plaintext PINs.

# Expo app → ViGlobal REST (`npm run api:dev`). Use LAN IP for physical devices.
EXPO_PUBLIC_REST_API_BASE="http://127.0.0.1:8787"
# Optional dev JWT (otherwise use loginRestApi + AsyncStorage token).
EXPO_PUBLIC_DEV_REST_JWT=""
# Demo booking targets (must exist in DB) for Ultra Master bento flows.
EXPO_PUBLIC_DEMO_BOOKING_BUSINESS_ID=""
EXPO_PUBLIC_DEMO_BOOKING_SERVICE_ID=""
