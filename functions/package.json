{
  "name": "ket-noi-eu-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify-bundle": "node ../scripts/verify-functions-bundle.mjs",
