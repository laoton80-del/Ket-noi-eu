# AWS SES (Sandbox / Production). Sao chép thành file `.env` và điền giá trị thật — không commit `.env`.
# Cảnh báo: nếu Access Key đã lộ công khai, hãy xoá và tạo key mới trong IAM.

AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Địa chỉ From phải đã verify trong SES (Sandbox: cả From và To đều phải verify).
AWS_SES_SENDER_EMAIL=laoton80@gmail.com

# API hardening (Express + Socket.IO) — comma-separated browser origins; TRUST_PROXY_HOPS=1 behind one ALB/nginx.
# API_CORS_ORIGINS=https://your-app.example.com,http://localhost:8081
# TRUST_PROXY_HOPS=0
