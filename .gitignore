# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# G5 optional trust:live success stamp (local / CI workspace)
.trust-live-stamp

# DevSecOps: never commit local secrets — `.env` must stay out of git (use EAS Secrets / CI).
.env
.env.*
!.env.example
.env*.local

# Firebase / GCP — keep out of git; inject via EAS secrets or CI (see app.config.js env paths).
google-services.json
GoogleService-Info.plist
*serviceAccount*.json
firebase-adminsdk*.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

.vercel

# Local visual QA (Puppeteer captures, one-off fullscreen tuning scripts)
qa-screenshots/
.screenshots-viona-*/
scripts/qa-fullscreen-*.mjs

# Tier-1 locale pack helpers (local/scratch — see docs/dev/VIONA_TIER1_LOCALE_BUILD_HELPERS_HYGIENE.md)
scripts/tier1-*-pack.json
scripts/_en-pilot-ns.json
scripts/_safety-bundle-en.json
scripts/_strings-en.json
scripts/_tier1-*-leaves.json
scripts/tr/
scripts/build-tier1-*.mjs
scripts/build-fr-ja-ko-safety.mjs
scripts/tier1-pack-build.mjs
scripts/_build-tier1-*.mjs
